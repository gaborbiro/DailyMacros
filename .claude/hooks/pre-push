#!/bin/bash
set -euo pipefail

REPO_OWNER="gaborbiro"
REPO_NAME="DailyMacros"

while read local_ref local_sha remote_ref remote_sha; do
    BRANCH="${remote_ref#refs/heads/}"

    if [ -z "${GITHUB_TOKEN:-}" ]; then
        echo "⚠ pre-push: GITHUB_TOKEN not set, skipping PR state check for '$BRANCH'"
        continue
    fi

    RESPONSE=$(curl -s -H "Authorization: Bearer $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/pulls?head=$REPO_OWNER:$BRANCH&state=all&per_page=1" 2>/dev/null || echo "[]")

    # sed -n exits 0 on no match (unlike grep, which would abort the hook
    # under set -euo pipefail) and tolerates both compact and pretty-printed
    # JSON. The pulls list API exposes merge state as "merged_at" (null or a
    # timestamp), not a "merged" boolean.
    STATE=$(echo "$RESPONSE" | sed -n 's/.*"state": *"\([^"]*\)".*/\1/p' | head -1)
    MERGED_AT=$(echo "$RESPONSE" | sed -n 's/.*"merged_at": *"\([^"]*\)".*/\1/p' | head -1)

    if [ -n "$MERGED_AT" ] || [ "$STATE" = "closed" ]; then
        echo ""
        echo "❌ Push blocked: the PR for branch '$BRANCH' is already MERGED/CLOSED."
        echo "   Create a new branch from master instead (cursor/description-XXXX)."
        echo ""
        exit 1
    fi
done

exit 0
