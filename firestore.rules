rules_version = '2';

// The app never touches Firestore directly. Only the OpenAI proxy Cloud
// Function reads/writes these documents, and it uses the Admin SDK, which
// bypasses security rules entirely. So we deny all client access: nobody can
// read the usage counters, spoof them, or flip the kill switch from a device.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
