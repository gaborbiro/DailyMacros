<?xml version="1.0" encoding="utf-8"?>
<!--
   Legacy Auto Backup rules for API < 31. The app's minSdk is 31, so in practice
   data_extraction_rules.xml governs backup/transfer; these rules are kept in
   sync for completeness. See
   https://developer.android.com/guide/topics/data/autobackup

   Exclude the shared-preferences files that hold credentials or PII (the
   encrypted BYO OpenAI key and the cloud-sync email / legacy plaintext key).
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secure_settings.xml" />
    <exclude domain="sharedpref" path="settings2.xml" />
</full-backup-content>
